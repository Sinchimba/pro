# Copy this file's contents into each service's own .env.example / .env
# This root file is just a reference of every variable used across the project.

# --- Backend ---
PORT=4000
FRONTEND_URL=http://localhost:5173
DATABASE_URL=            # PlanetScale MySQL connection string
REDIS_URL=                # Upstash Redis connection string

# --- Frontend ---
VITE_BACKEND_URL=http://localhost:4000
VITE_TURN_URL=             # your TURN server URL
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# --- AI Service ---
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=